# Copia questo file in .env e compila i valori
#
# SESSION_SECRET: genera con →  python3 -c "import secrets; print(secrets.token_hex(32))"
# DATABASE_URL:   mysql+pymysql://utente:password@host:porta/nome_db
#                 oppure sqlite:///webapp.db per sviluppo locale senza MySQL

DATABASE_URL=mysql+pymysql://utente:password@localhost:3306/prometeo
SESSION_SECRET=
